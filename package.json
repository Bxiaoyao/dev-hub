{
  "name": "devhub",
  "version": "0.1.0",
  "description": "一站式管理本地开发项目：项目浏览、分支管理、依赖管理、环境导出/导入、一键启动编辑器",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "devhub": "./bin/devhub.mjs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "vite",
    "dev:server": "tsx src/server/index.ts",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:web": "vite build",
    "start": "node bin/devhub.mjs",
    "start:daemon": "./scripts/devhub-start.sh start",
    "stop:daemon": "./scripts/devhub-start.sh stop",
    "update": "./scripts/install.sh update",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest"
  },
  "keywords": [
    "cli",
    "project-manager",
    "git",
    "dev-tools",
    "web-ui"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "execa": "^9.1.0",
    "express": "^4.21.2",
    "fast-glob": "^3.3.2",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.25.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vite": "^6.3.5",
    "vitest": "^1.6.0"
  }
}
